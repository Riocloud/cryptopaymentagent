// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 用户
model User {
  id            String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // 关联
  exchanges    ExchangeBinding[]
  wallets      Wallet[]
  payments     Payment[]
  intents      UserIntent[]

  // 索引
  @@index([createdAt])
}

// 交易所绑定
model ExchangeBinding {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  exchange    String   // binance, okx, coinbase, bybit
  authType    String   // oauth, api_key
  
  // 加密存储的凭证
  credentials String   // 加密后的 JSON
  
  permissions String   // comma-separated: 'spot,wallet,trade'
  
  createdAt   DateTime @default(now())
  expiresAt   DateTime? // OAuth 时需要
  updatedAt   DateTime @updatedAt

  @@unique([userId, exchange])
  @@index([userId])
  @@index([exchange])
}

// 钱包/Key
model Wallet {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  chain       String   // solana, ethereum, polygon, tron
  address     String
  
  // Keystore 加密
  keystore    String?  // 导用户自托管出的 keystore ()
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, chain, address])
  @@index([userId])
  @@index([chain])
}

// 支付请求
model Payment {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amountUSD     Float     // USD 金额
  token         String    // USDC, USDT
  fromChain     String
  toChain       String
  toAddress     String    // 收款方地址
  
  status        String    // pending, processing, completed, failed
  routeDetails  String?   // 路由详情 JSON
  
  txHash        String?   // 链上交易 hash
  errorMessage  String?   // 失败原因
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// 支付路由缓存
model PaymentRoute {
  id            String   @id @default(uuid())
  
  fromChain     String
  toChain       String
  fromToken     String
  toToken       String
  
  routeData     String   // 路由详情 JSON
  
  totalCostUSD  Float
  totalTimeSec  Int
  
  expiresAt     DateTime // 缓存过期时间
  
  createdAt     DateTime @default(now())

  @@unique([fromChain, toChain, fromToken, toToken])
  @@index([fromChain, toChain])
}

// 用户意图 (Phase 2)
model UserIntent {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        String   // transport, food, shopping, service
  intent      String   // JSON
  
  // 广告相关
  preferences String?  // JSON: { wantAds: true, maxWaitMinutes: 10, maxGroupSize: 4 }
  
  status      String   // pending, matching, matched, completed, cancelled
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expiresAt   DateTime?

  @@index([userId])
  @@index([status])
}

// Agent 广告出价 (Phase 2 新增)
model AgentBid {
  id          String   @id @default(uuid())
  
  agentId     String   // Agent ID
  intentId    String   // 关联的 Intent
  
  bidType     String   // driver_bid, restaurant_promo, service_offer, affiliate
  
  // 出价
  amount      Float    // 愿意支付的费用
  originalPrice Float? // 原始价格
  discount    String?  // 让利: "25%"
  
  // 附加信息
  eta         Int?     // 预计到达时间(分钟)
  rating      Float?
  message     String?
  
  status      String   // pending, accepted, rejected
  
  createdAt   DateTime @default(now())
  
  @@index([agentId])
  @@index([intentId])
  @@index([status])
}

// Phase 3: 收益账户 (Yield)
model YieldAccount {
  id            String   @id @default(uuid())
  userId        String   @unique
  
  // 风险级别
  riskLevel     String   // conservative, moderate, aggressive
  
  // 自动复投
  autoCompound  Boolean  @default(false)
  
  // 总资产 USD
  totalValueUSD Float    @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // 关联
  holdings      YieldHolding[]
  records       YieldRecord[]
}

// 持仓
model YieldHolding {
  id            String   @id @default(uuid())
  accountId     String
  account       YieldAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  token         String   // USDC, USDT, etc
  chain         String   // solana, ethereum, etc
  amount        Float
  
  protocol      String   // aave, raydium, etc
  apy           Float    // 当前 APY
  
  valueUSD      Float    @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([accountId])
  @@index([token])
}

// 收益历史
model YieldRecord {
  id            String   @id @default(uuid())
  accountId     String
  account       YieldAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  amountUSD     Float
  source        String   // interest, reward, arbitrage
  
  createdAt     DateTime @default(now())
  
  @@index([accountId])
}

// Phase 2.5: 托管系统 (Escrow)
model Escrow {
  id            String   @id @default(uuid())
  
  // 关联
  paymentId     String?  // 关联的 Payment
  groupId       String?  // 关联的 Group
  
  // 金额
  amountUSD     Float
  token         String   // USDC, USDT
  chain         String
  
  // 参与方
  payerId       String   // 付款方
  payeeId       String   // 收款方 (Agent/司机)
  
  // 状态
  status        String   // pending, locked, released, disputed, refunded
  
  // 托管时间
  lockedAt      DateTime?
  releasedAt    DateTime?
  expiresAt     DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([payerId])
  @@index([payeeId])
  @@index([status])
}

// Phase 2.5: 声誉系统
model Reputation {
  id            String   @id @default(uuid())
  
  entityType    String   // 'user' | 'agent'
  entityId      String
  
  // 分数 (0-100)
  score         Float    @default(50)
  
  // 统计
  totalRatings  Int      @default(0)
  positiveRatings Int    @default(0)
  negativeRatings Int    @default(0)
  
  // 争议次数
  disputes      Int      @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([entityType, entityId])
  @@index([entityId])
}

// 评分记录
model Rating {
  id            String   @id @default(uuid())
  
  // 评分者
  raterType     String   // 'user' | 'agent'
  raterId       String
  
  // 被评者
  targetType    String   // 'user' | 'agent'
  targetId      String
  
  // 分数 (-1, 0, 1) 或 (1-5)
  score         Int
  
  // 原因
  reason        String?  // 'on_time' | 'no_show' | 'good_service' | etc.
  comment       String?
  
  // 关联交易
  escrowId      String?
  
  createdAt     DateTime @default(now())
  
  @@index([targetId])
  @@index([raterId])
}

// Phase 2.5: Agent 保证金
model AgentBond {
  id            String   @id @default(uuid())
  
  agentId       String   @unique
  
  // 保证金金额
  bondAmountUSD Float    @default(0)
  
  // 状态
  status        String   // active, frozen, released
  
  // 冻结原因
  frozenReason  String?
  frozenAt     DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([agentId])
}
